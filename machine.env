# Product firmware machine configuration.
# Edit this file for each airframe, then run ./scripts/deploy.sh.

# PX4 <-> onboard computer UART
FCU_DEVICE=/dev/ttyTHS0
FCU_BAUD=115200

# MID360 serial number used by livox_ros_driver2
MID360_BD_LIST=147MDLC40020242

# Last two digits of the MID360 serial number.
# The default rule derives the LiDAR IP as 192.168.1.(100 + suffix).
MID360_SN_SUFFIX=42

# Leave empty to use the derived IP rule above.
# Example override: 192.168.1.142
MID360_LIDAR_IP=

# Ethernet interface connected to the MID360
HOST_ETH_IFACE=eth0
HOST_ETH_IP=192.168.1.50
HOST_ETH_PREFIX=24
HOST_ETH_GATEWAY=

# MID360 port configuration
MID360_CMD_DATA_PORT=56100
MID360_PUSH_MSG_PORT=56200
MID360_POINT_DATA_PORT=56300
MID360_IMU_DATA_PORT=56400
MID360_LOG_DATA_PORT=56500

# Host port configuration
HOST_CMD_DATA_PORT=56101
HOST_PUSH_MSG_PORT=56201
HOST_POINT_DATA_PORT=56301
HOST_IMU_DATA_PORT=56401
HOST_LOG_DATA_PORT=56501

# Set to true only if log_data_ip must be written into MID360_config.json
MID360_SET_LOG_DATA_IP=false
