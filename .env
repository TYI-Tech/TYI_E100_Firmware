IMAGE_NAME=crpi-zpvbhgsm3t97idht.cn-hangzhou.personal.cr.aliyuncs.com/tyi-tech/tyi_e100:0.1.2
CONTAINER_NAME=uav-base-stack-customer

DISPLAY=
ROS_MASTER_PORT=11311
FCU_URL=/dev/ttyTHS0:115200
GCS_URL=udp://@192.168.110.227:14550
MAVROS_TGT_SYSTEM=1
MAVROS_TGT_COMPONENT=1
MAVROS_FCU_PROTOCOL=v2.0
MAVROS_LOG_OUTPUT=screen
MAVROS_RESPAWN=false

LIVOX_BD_LIST=147MDLC40020242
LIVOX_FRAME_ID=livox_frame
LIVOX_PUBLISH_FREQ=20.0

DLIO_NAMESPACE=robot
STRICT_TOPIC_HEALTHCHECK=false
TYI_TIMEBASE_MODE=monotonic_raw_epoch
TYI_TIMEBASE_FILE=/tmp/tyi_timebase.env
